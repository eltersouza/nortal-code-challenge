{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=gameoflife.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "GameOfLife": {
    "MaxBoardSize": 1000,
    "MaxGenerations": 10000,
    "DefaultMaxGenerations": 1000
  },
  "AllowedHosts": "*"
}
